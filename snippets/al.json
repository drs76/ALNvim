{
  "Table Object": {
    "prefix": "ttable",
    "body": [
      "table ${1:50000} ${2:MyTable}",
      "{",
      "    DataClassification = ${3|CustomerContent,AccountData,EndUserIdentifiableInformation,EndUserPseudonymousIdentifiers,OrganizationIdentifiableInformation,SystemMetadata,ToBeClassified|};",
      "",
      "    fields",
      "    {",
      "        field(1; ${4:PrimaryKey}; ${5:Code[20]})",
      "        {",
      "            Caption = '${4:PrimaryKey}';",
      "            DataClassification = ${3};",
      "        }",
      "        $0",
      "    }",
      "",
      "    keys",
      "    {",
      "        key(PK; ${4:PrimaryKey}) { Clustered = true; }",
      "    }",
      "}"
    ],
    "description": "AL Table object template"
  },
